COMPOOL NAV'POOL;
BEGIN

  TYPE COORD'TYPE S 32;

  ITEM MAX'WAYPOINTS CONSTANT S 32 = 256;

  TABLE WAYPOINT(0:255);
  BEGIN
    ITEM LAT F 64;
    ITEM LON F 64;
    ITEM ALT S 32;
    ITEM ACTIVE B 1;
  END

  TYPE HEADING STATUS(V(NORTH), V(SOUTH), V(EAST), V(WEST));

  ITEM CURRENT'HDG HEADING = V(NORTH);

END
